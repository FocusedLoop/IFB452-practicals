					"contents": "{\n\n    function array_storeLengthForEncoding_t_string_memory_ptr_fromStack(pos, length) -> updated_pos {\n        mstore(pos, length)\n        updated_pos := add(pos, 0x20)\n    }\n\n    function store_literal_in_memory_5d9d8c36fbf257bda34d6c952a13c89e99798f951ee728ba9ffcd8766ff04a0f(memPtr) {\n\n        mstore(add(memPtr, 0), \"Hellow World!\")\n\n    }\n\n    function abi_encode_t_stringliteral_5d9d8c36fbf257bda34d6c952a13c89e99798f951ee728ba9ffcd8766ff04a0f_to_t_string_memory_ptr_fromStack(pos) -> end {\n        pos := array_storeLengthForEncoding_t_string_memory_ptr_fromStack(pos, 13)\n        store_literal_in_memory_5d9d8c36fbf257bda34d6c952a13c89e99798f951ee728ba9ffcd8766ff04a0f(pos)\n        end := add(pos, 32)\n    }\n\n    function abi_encode_tuple_t_stringliteral_5d9d8c36fbf257bda34d6c952a13c89e99798f951ee728ba9ffcd8766ff04a0f__to_t_string_memory_ptr__fromStack_reversed(headStart ) -> tail {\n        tail := add(headStart, 32)\n\n        mstore(add(headStart, 0), sub(tail, headStart))\n        tail := abi_encode_t_stringliteral_5d9d8c36fbf257bda34d6c952a13c89e99798f951ee728ba9ffcd8766ff04a0f_to_t_string_memory_ptr_fromStack( tail)\n\n    }\n\n}\n",
